# .env.production — NEVER commit this file. Store in GitHub Secrets or a vault.
# Copy to /opt/app/.env on the VPS.

# ── Domain ───────────────────────────────────────────────────
DOMAIN=yourdomain.com
ACME_EMAIL=ops@yourdomain.com

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
JWT_SECRET=generate-with--openssl-rand-base64-64
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=generate-with--openssl-rand-base64-64
JWT_REFRESH_EXPIRES_IN=7d

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=appuser
POSTGRES_PASSWORD=generate-with--openssl-rand-base64-32
POSTGRES_DB=appdb

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=generate-with--openssl-rand-base64-32

# ── MinIO / Object Storage ───────────────────────────────────
MINIO_ACCESS_KEY=generate-with--openssl-rand-hex-20
MINIO_SECRET_KEY=generate-with--openssl-rand-base64-40

# ── Traefik Dashboard ────────────────────────────────────────
# Generate: htpasswd -nB admin | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$12$$...

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_PASSWORD=generate-strong-password

# ── SMTP (for Grafana alerts) ────────────────────────────────
SMTP_HOST=smtp.sendgrid.net:587
SMTP_USER=apikey
SMTP_PASSWORD=SG.xxxxxxxxxxxx

# ── Docker Image ─────────────────────────────────────────────
DOCKER_REGISTRY=ghcr.io
IMAGE_NAME=your-org/your-repo
IMAGE_TAG=latest

# ── Cloudflare (only if using DNS challenge for wildcard TLS) ─
# CF_DNS_API_TOKEN=your-cloudflare-api-token

# ── Alerting ─────────────────────────────────────────────────
SLACK_WEBHOOK=https://hooks.slack.com/services/...
